# Copy this file to `.env` and fill in real values if you need to override defaults.
# `.env` is gitignored and never synced. sysperf needs NO secrets and NO env vars to run;
# everything below is OPTIONAL and exists only so the standard's preflight has a schema to check.
#
# All of these mirror keys in config/default.json and can also be passed as CLI flags.

# Procfs root the collectors read (default: /proc). Point at a fixture tree for debugging.
SYSPERF_PROC_ROOT=/proc

# Sysfs root the collectors read (default: /sys).
SYSPERF_SYS_ROOT=/sys

# Sample interval in milliseconds (default: 1000 = 1 Hz).
SYSPERF_INTERVAL_MS=1000

# Path to a JSON config file to load instead of ./config/default.json (optional).
SYSPERF_CONFIG=
